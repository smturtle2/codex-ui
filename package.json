{
  "name": "codex-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "node scripts/launcher.mjs setup",
    "doctor": "node scripts/launcher.mjs doctor",
    "up": "node scripts/launcher.mjs dev",
    "up:prod": "node scripts/launcher.mjs start",
    "dev": "node scripts/launcher.mjs dev",
    "dev:raw": "tsx watch server/index.ts",
    "build": "next build",
    "start": "node scripts/launcher.mjs start",
    "start:raw": "NODE_ENV=production tsx server/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "8.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
